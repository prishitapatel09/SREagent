# --- LLM (any OpenAI-compatible endpoint; defaults = local Ollama) ---
# Ollama:      LLM_BASE_URL=http://host.docker.internal:11434/v1  LLM_API_KEY=ollama  LLM_MODEL=qwen3:8b
#              (Linux: start Ollama with OLLAMA_HOST=0.0.0.0 so containers can reach it)
# OpenRouter:  LLM_BASE_URL=https://openrouter.ai/api/v1          LLM_API_KEY=sk-or-...  LLM_MODEL=qwen/qwen3-32b
# DashScope:   LLM_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1  LLM_MODEL=qwen-plus
LLM_BASE_URL=http://host.docker.internal:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=qwen3:8b
LLM_TIMEOUT_S=60
MAX_TOOL_CALLS=10

# live = real LLM; stub = deterministic scripted investigator (no LLM needed —
# used by tests and as the demo fallback if Ollama is down)
AGENT_MODE=live

# Slack incoming webhook. Leave empty to fall back to a console/dashboard card.
SLACK_WEBHOOK_URL=

# Load generator request rate against shopapi
RPS=10
